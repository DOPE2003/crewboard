generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SUPPORT
  ADMIN
  OWNER
}

model User {
  id                   String                @id @default(cuid())
  twitterId            String?               @unique
  twitterHandle        String                @unique
  name                 String?
  image                String?
  userTitle            String?               // Job title like "AI Engineer"
  role                 Role                  @default(USER)
  skills               String[]
  bio                  String?
  availability         String?
  profileComplete      Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  walletAddress        String?               @unique
  isOG                 Boolean               @default(false)
  ogGrantedAt          DateTime?
  ogFoundingClient     Boolean               @default(false)
  worldIdLevel         String?
  worldIdNullifier     String?               @unique
  stripeVerificationId String?               @unique
  email                String?               @unique
  passwordHash         String?
  emailVerified        DateTime?
  lastSeenAt           DateTime?
  portfolioItems       Json                  @default("[]")
  cvUrl                String?
  twitterHandle2       String?
  telegramHandle       String?
  githubHandle         String?
  discordHandle        String?
  linkedinHandle       String?
  website              String?
  website2             String?
  website3             String?
  bannerImage          String?
  bannerHeight         Int                   @default(140)
  humanVerified        Boolean               @default(false)
  gigs                 Gig[]
  jobs                 Job[]
  jobApplications      JobApplication[]
  sentMessages         Message[]
  notifications        Notification[]
  buyerOrders          Order[]               @relation("BuyerOrders")
  sellerOrders         Order[]               @relation("SellerOrders")
  reviewsReceived      Review[]              @relation("ReviewsReceived")
  reviewsGiven         Review[]              @relation("ReviewsGiven")
  savedByTalents       SavedTalent[]         @relation("SavedMe")
  savedTalents         SavedTalent[]         @relation("SavedByMe")
  savedGigs            SavedGig[]
  sentOffers           Offer[]               @relation("SentOffers")
  receivedOffers       Offer[]               @relation("ReceivedOffers")
  showcaseInteractions ShowcaseInteraction[]
  showcasePosts        ShowcasePost[]
  proWaitlist          ProWaitlist?
  campaignClaims       CampaignClaim[]
  passwordResetTokens     PasswordResetToken[]
  emailVerifyTokens       EmailVerifyToken[]
  notificationPreferences NotificationPreferences?
  filedDisputes        Dispute[]        @relation("FiledDisputes")
  disputeMessages      DisputeMessage[] @relation("DisputeMessages")
  supportTickets       SupportTicket[]
}

model SavedTalent {
  id          String   @id @default(cuid())
  saverId     String
  savedUserId String
  createdAt   DateTime @default(now())
  savedUser   User     @relation("SavedMe", fields: [savedUserId], references: [id], onDelete: Cascade)
  saver       User     @relation("SavedByMe", fields: [saverId], references: [id], onDelete: Cascade)

  @@unique([saverId, savedUserId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("system")
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  link        String?
  actionUrl   String?
  senderImage String?
  messageId   String?  // dedup key: one notification per (user, message)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@unique([userId, messageId]) // nulls don't conflict — only enforces dedup when messageId is set
}

model Job {
  id          String   @id @default(cuid())
  title       String
  company     String
  budget      String
  duration    String?
  chain       String   @default("ETH")
  category    String   @default("Development")
  level       String   @default("Senior")
  jobType     String   @default("Remote")
  tags        String[]
  description String
  milestones  Boolean  @default(false)
  status                String   @default("open")
  ownerId               String
  acceptedApplicantId   String?
  createdAt             DateTime @default(now())
  owner                 User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  applications          JobApplication[]

  @@index([status])
  @@index([chain])
}

model JobApplication {
  id            String   @id @default(cuid())
  jobId         String
  applicantId   String
  coverLetter   String
  proposedRate  String?
  portfolioURL  String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  job       Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant User @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([jobId, applicantId])
  @@index([jobId, status])
  @@index([applicantId, status])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  ownerId     String
  stack       String[]
  rolesNeeded String[]
  status      String   @default("open")
  createdAt   DateTime @default(now())
}

model Conversation {
  id             String    @id @default(cuid())
  participants   String[]
  participantKey String?   @unique // sorted participants joined with ":" — prevents duplicate convs
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  messages       Message[]
  offers         Offer[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  replyToId      String?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReplies")
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model Gig {
  id           String     @id @default(cuid())
  userId       String
  title        String
  description  String
  price        Int
  deliveryDays Int
  category     String
  tags         String[]
  status       String     @default("active")
  image        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  savedBy      SavedGig[]

  @@index([userId, status])
}

model SavedGig {
  id        String   @id @default(cuid())
  userId    String
  gigId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gig       Gig      @relation(fields: [gigId], references: [id], onDelete: Cascade)

  @@unique([userId, gigId])
  @@index([userId])
}

model Order {
  id                  String    @id @default(cuid())
  gigId               String
  buyerId             String
  sellerId            String
  amount              Int
  status              String    @default("pending")
  escrowAddress       String?   @unique
  txHash              String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deliveryNote        String?
  deliveryFiles       Json?
  deliverySubmittedAt DateTime?
  deliveryHistory     Json      @default("[]")
  revisionRequests    Json      @default("[]")
  revisionCount       Int       @default(0)
  feeOverridePct      Float?
  campaignClaimId     String?
  buyer               User      @relation("BuyerOrders", fields: [buyerId], references: [id], onDelete: Cascade)
  gig                 Gig       @relation(fields: [gigId], references: [id], onDelete: Cascade)
  seller              User      @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)
  reviews             Review[]
  offer               Offer?
  disputes            Dispute[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

model Review {
  id         String   @id @default(cuid())
  orderId    String
  reviewerId String
  revieweeId String
  rating     Int
  body       String?
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([orderId, reviewerId])
}

model ShowcasePost {
  id           String                @id @default(cuid())
  userId       String
  title        String
  description  String?
  mediaUrl     String
  mediaType    String
  category     String
  tags         String[]
  views        Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  interactions ShowcaseInteraction[]
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ShowcaseInteraction {
  id           String       @id @default(cuid())
  userId       String
  postId       String
  type         String
  watchPercent Int?
  createdAt    DateTime     @default(now())
  post         ShowcasePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProWaitlist {
  id       String   @id @default(cuid())
  userId   String   @unique
  joinedAt DateTime @default(now())
  notified Boolean  @default(false)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreferences {
  userId         String   @id
  jobAlerts      Boolean  @default(true)
  jobCategories  String[] @default([])
  offerAlerts    Boolean  @default(true)
  chatAlerts     Boolean  @default(true)
  marketing      Boolean  @default(false)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerifyToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Dispute {
  id                  String           @id @default(cuid())
  orderId             String
  filedById           String
  reason              String
  description         String
  status              String           @default("open")
  previousOrderStatus String?
  resolution          Json?
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  order    Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filedBy  User             @relation("FiledDisputes",        fields: [filedById], references: [id], onDelete: Cascade)
  evidence DisputeEvidence[]
  messages DisputeMessage[]

  @@index([orderId])
  @@index([filedById])
}

model DisputeEvidence {
  id        String   @id @default(cuid())
  disputeId String
  type      String
  url       String?
  text      String?
  createdAt DateTime @default(now())
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

model DisputeMessage {
  id        String   @id @default(cuid())
  disputeId String
  senderId  String?
  body      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  dispute   Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender    User?    @relation("DisputeMessages", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([disputeId, createdAt])
}

model Offer {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  receiverId     String
  title          String
  description    String
  amount         Int
  deliveryDays   Int
  status         String       @default("pending")
  orderId        String?      @unique
  milestones     Json?
  attachments    Json?
  clientContact  String?
  currency       String       @default("USD")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentOffers", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User         @relation("ReceivedOffers", fields: [receiverId], references: [id], onDelete: Cascade)
  order          Order?       @relation(fields: [orderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
}

model SupportTicket {
  id          String    @id @default(cuid())
  userId      String
  subject     String
  category    String    @default("general")
  body        String
  status      String    @default("open")
  staffNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  resolvedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model AdminActionLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt])
}

model CampaignClaim {
  id                   String    @id @default(cuid())
  campaign             String
  walletAddress        String
  userId               String?
  status               String    @default("pending") // pending | qualified | redeemed | expired
  creditAmountUsdc     Int       @default(5000)       // $50 in cents
  creditRemainingUsdc  Int       @default(5000)
  feeRebatesRemaining  Int       @default(3)
  ogBadgeGranted       Boolean   @default(false)
  claimedAt            DateTime  @default(now())
  redeemedAt           DateTime?
  firstOrderId         String?
  expiresAt            DateTime
  user                 User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([campaign, walletAddress])
  @@index([campaign, status])
  @@index([userId])
  @@map("campaign_claim")
}
