generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  SUPPORT
  ADMIN
}

model User {
  id                   String                @id @default(cuid())
  twitterId            String?               @unique
  twitterHandle        String                @unique
  name                 String?
  image                String?
  userTitle            String?               // Job title like "AI Engineer"
  role                 Role                  @default(USER)
  skills               String[]
  bio                  String?
  availability         String?
  profileComplete      Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  walletAddress        String?               @unique
  isOG                 Boolean               @default(false)
  worldIdLevel         String?
  worldIdNullifier     String?               @unique
  stripeVerificationId String?               @unique
  email                String?               @unique
  passwordHash         String?
  lastSeenAt           DateTime?
  portfolioItems       Json                  @default("[]")
  cvUrl                String?
  twitterHandle2       String?
  telegramHandle       String?
  githubHandle         String?
  discordHandle        String?
  linkedinHandle       String?
  website              String?
  website2             String?
  website3             String?
  bannerImage          String?
  bannerHeight         Int                   @default(140)
  humanVerified        Boolean               @default(false)
  gigs                 Gig[]
  sentMessages         Message[]
  notifications        Notification[]
  buyerOrders          Order[]               @relation("BuyerOrders")
  sellerOrders         Order[]               @relation("SellerOrders")
  reviewsReceived      Review[]              @relation("ReviewsReceived")
  reviewsGiven         Review[]              @relation("ReviewsGiven")
  savedByTalents       SavedTalent[]         @relation("SavedMe")
  savedTalents         SavedTalent[]         @relation("SavedByMe")
  savedGigs            SavedGig[]
  showcaseInteractions ShowcaseInteraction[]
  showcasePosts        ShowcasePost[]
  proWaitlist          ProWaitlist?
  passwordResetTokens  PasswordResetToken[]
}

model SavedTalent {
  id          String   @id @default(cuid())
  saverId     String
  savedUserId String
  createdAt   DateTime @default(now())
  savedUser   User     @relation("SavedMe", fields: [savedUserId], references: [id], onDelete: Cascade)
  saver       User     @relation("SavedByMe", fields: [saverId], references: [id], onDelete: Cascade)

  @@unique([saverId, savedUserId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("system")
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  link      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  ownerId     String
  stack       String[]
  rolesNeeded String[]
  status      String   @default("open")
  createdAt   DateTime @default(now())
}

model Conversation {
  id           String    @id @default(cuid())
  participants String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  replyToId      String?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies        Message[]    @relation("MessageReplies")
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Gig {
  id           String     @id @default(cuid())
  userId       String
  title        String
  description  String
  price        Int
  deliveryDays Int
  category     String
  tags         String[]
  status       String     @default("active")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  savedBy      SavedGig[]

  @@index([userId, status])
}

model SavedGig {
  id        String   @id @default(cuid())
  userId    String
  gigId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gig       Gig      @relation(fields: [gigId], references: [id], onDelete: Cascade)

  @@unique([userId, gigId])
  @@index([userId])
}

model Order {
  id            String   @id @default(cuid())
  gigId         String
  buyerId       String
  sellerId      String
  amount        Int
  status        String   @default("pending")
  escrowAddress String?  @unique
  txHash        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  buyer         User     @relation("BuyerOrders", fields: [buyerId], references: [id])
  gig           Gig      @relation(fields: [gigId], references: [id])
  seller        User     @relation("SellerOrders", fields: [sellerId], references: [id])
  reviews       Review[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

model Review {
  id         String   @id @default(cuid())
  orderId    String
  reviewerId String
  revieweeId String
  rating     Int
  body       String?
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([orderId, reviewerId])
}

model ShowcasePost {
  id           String                @id @default(cuid())
  userId       String
  title        String
  description  String?
  mediaUrl     String
  mediaType    String
  category     String
  tags         String[]
  views        Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  interactions ShowcaseInteraction[]
  user         User                  @relation(fields: [userId], references: [id])
}

model ShowcaseInteraction {
  id           String       @id @default(cuid())
  userId       String
  postId       String
  type         String
  watchPercent Int?
  createdAt    DateTime     @default(now())
  post         ShowcasePost @relation(fields: [postId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model ProWaitlist {
  id       String   @id @default(cuid())
  userId   String   @unique
  joinedAt DateTime @default(now())
  notified Boolean  @default(false)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
